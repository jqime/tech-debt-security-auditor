# ── CodeAudit Pro ── Configuración ──────────────────────────────────
# Copia este archivo a .env y completa los valores

# ── Dominio público (para URLs de Stripe, links en emails) ──────────
DOMAIN=http://localhost:5001

# ── Base de datos (omite para SQLite, usa URL de PostgreSQL para prod)
DATABASE_URL=

# ── Stripe (pagos) ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email (Gmail SMTP) ──────────────────────────────────────────────
EMAIL_USER=
EMAIL_PASS=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ── Dashboard ───────────────────────────────────────────────────────
DASHBOARD_USER=admin
DASHBOARD_PASS=
DASHBOARD_SECRET=cambiar-en-produccion-123456
DASHBOARD_PORT=5000

# ── Landing handler ─────────────────────────────────────────────────
LANDING_PORT=5001

# ── Payment server ─────────────────────────────────────────────────
PAYMENT_PORT=5002

# ── Continuous audit ────────────────────────────────────────────────
CONTINUOUS_PORT=5003
GITHUB_WEBHOOK_SECRET=

# ── Runner ──────────────────────────────────────────────────────────
RUNNER_INTERVAL=30

# ── Jira ────────────────────────────────────────────────────────────
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# ── SIEM ────────────────────────────────────────────────────────────
SIEM_WEBHOOK_URL=
SIEM_TOKEN=
SIEM_TYPE=generic

# ── GitHub (remediación automática) ─────────────────────────────────
GITHUB_TOKEN=

# ── Slack (alertas) ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
