[Unit]
Description=CodeAudit Pro — Continuous Audit / GitHub Webhooks
Documentation=https://github.com/jqime/tech-debt-security-auditor
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/codeauditpro
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 continuous_audit.py --daemon
Restart=always
RestartSec=5

NoNewPrivileges=yes
ProtectHome=yes
PrivateDevices=yes
ProtectSystem=full

[Install]
WantedBy=multi-user.target
